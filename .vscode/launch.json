{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Multi-File App",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${binaryLabel}.exe", // Points to your compiled binary
            "args": [], // You can pass runtime CLI arguments here if needed
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true, // 💡 Sets up an external terminal windows for interactive cin inputs
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe", // 💡 Path to your GDB debugger
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Multi-File Project" // 🔴 MUST MATCH THE LABEL IN TASKS.JSON
        }
    ]
}