{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Multi-File Project",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe", // 💡 Path to your compiler
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",                     // 🔴 CRITICAL: Generates debugging symbols
                "${fileDirname}/*.cpp",   // 💡 COMPILES ALL .cpp FILES IN THE DIR
                "-o",
                "${fileDirname}/${binaryLabel}.exe" 
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compiler task to bundle all source files with debug flags."
        }
    ]
}